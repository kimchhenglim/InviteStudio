@page "{id:guid}"
@model InviteStudio.Web.Pages.Events.AddGuestModel
@{
    ViewData["Title"] = "Add guest";
}

<div class="event-detail-hero">
    <div class="container">
        <nav class="event-detail-menu">
            <a class="event-detail-menu-link" asp-page="/Events/Details" asp-route-id="@Model.Event?.Id">General</a>
            <a class="event-detail-menu-link" asp-page="/Events/DesignCard" asp-route-id="@Model.Event?.Id">Invitation design</a>
            <a class="event-detail-menu-link is-active" asp-page="/Events/Guests" asp-route-id="@Model.Event?.Id">Guests</a>
        </nav>
        <div class="event-detail-header">
            <div>
                <span class="event-detail-eyebrow">Guests</span>
                <h1>@Model.EventTitle</h1>
                <p class="event-detail-subtitle">@Model.EventSubtitle</p>
            </div>
            <div class="event-detail-actions">
                <a class="btn btn-outline-primary" asp-page="/Events/Guests" asp-route-id="@Model.Event?.Id">Back to guests</a>
            </div>
        </div>
    </div>
</div>

<div class="container pb-5">
    <div class="row g-4 justify-content-center">
        <div class="col-12 col-lg-7">
            <section class="event-detail-card">
                <div class="event-detail-section">
                    <div>
                        <span class="event-detail-label">Add guest</span>
                        <h2>New invitee</h2>
                    </div>
                </div>
                <form method="post">
                    <div class="event-design-grid">
                        <div>
                            <label class="form-label" asp-for="Input.Name">Guest name</label>
                            <input class="form-control" asp-for="Input.Name" />
                            <span class="text-danger" asp-validation-for="Input.Name"></span>
                        </div>
                        <div>
                            <label class="form-label" asp-for="Input.PhoneNumber">Phone number</label>
                            <input class="form-control" asp-for="Input.PhoneNumber" />
                        </div>
                        <div>
                            <label class="form-label" asp-for="Input.TagId">Tag</label>
                            <select class="form-select" asp-for="Input.TagId">
                                <option value="">Select a tag</option>
                                @foreach (var tag in Model.GuestTags)
                                {
                                    <option value="@tag.Id">@tag.Name</option>
                                }
                            </select>
                            <span class="text-danger" asp-validation-for="Input.TagId"></span>
                        </div>
                        <div>
                            <label class="form-label" asp-for="Input.TagName">Or create a new tag</label>
                            <input class="form-control" asp-for="Input.TagName" />
                        </div>
                        <div>
                            <label class="form-label" asp-for="Input.Notes">Notes</label>
                            <textarea class="form-control" asp-for="Input.Notes" rows="3"></textarea>
                        </div>
                        <div class="d-flex gap-2">
                            <button class="btn btn-primary" type="submit">Create guest</button>
                            <a class="btn btn-outline-primary" asp-page="/Events/Guests" asp-route-id="@Model.Event?.Id">Cancel</a>
                        </div>
                    </div>
                </form>
            </section>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
