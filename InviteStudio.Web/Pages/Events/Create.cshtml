@page
@model InviteStudio.Web.Pages.Events.CreateModel
@{
    ViewData["Title"] = "Create event";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-12 col-lg-8">
            <div class="event-create-card">
                <h1 class="h3 mb-3">Create a new event</h1>
                <p class="text-muted mb-4">Start with a name and basic details. You can finish setup later.</p>

                <div class="d-flex flex-column gap-3">
                    <div>
                        <label class="form-label">Event name</label>
                        <input class="form-control" placeholder="e.g. Spring Wedding" />
                    </div>
                    <div>
                        <label class="form-label">Event date</label>
                        <input class="form-control" type="date" />
                    </div>
                    <div>
                        <label class="form-label">Location</label>
                        <input class="form-control" placeholder="City or venue" />
                    </div>
                    <div class="d-flex gap-2">
                        <button class="btn btn-primary" type="button">Continue</button>
                        <a class="btn btn-outline-primary" asp-page="/Home/Index">Cancel</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
