@page
@model InviteStudio.Web.Pages.Events.CreateModel
@{
    ViewData["Title"] = "Create event";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-12 col-lg-8">
            <div class="event-create-card">
                <h1 class="h3 mb-3">Create a new event</h1>
                <p class="text-muted mb-4">Start with some details. You can finish setup later.</p>

                <form method="post" class="d-flex flex-column gap-3">
                    <div>
                        <label class="form-label" asp-for="Input.EventType"></label>
                        <select class="form-select" asp-for="Input.EventType" asp-items="Model.EventTypeOptions">
                            <option value="">Select event type</option>
                        </select>
                        <span class="text-danger" asp-validation-for="Input.EventType"></span>
                    </div>
                    <div id="personFields" class="d-flex flex-column gap-3">
                        <div id="personFields1">
                            <label id="person1Label" class="form-label" asp-for="Input.Person1Name"></label>
                            <input class="form-control" asp-for="Input.Person1Name" />
                            <span class="text-danger" asp-validation-for="Input.Person1Name"></span>
                        </div>
                        <div id="personFields2">
                            <label id="person2Label" class="form-label" asp-for="Input.Person2Name"></label>
                            <input class="form-control" asp-for="Input.Person2Name" />
                            <span class="text-danger" asp-validation-for="Input.Person2Name"></span>
                        </div>
                    </div>
                    <div>
                        <label class="form-label" asp-for="Input.EventDate"></label>
                        <input class="form-control" asp-for="Input.EventDate" type="date" />
                        <span class="text-danger" asp-validation-for="Input.EventDate"></span>
                    </div>
                    <div>
                        <label class="form-label" asp-for="Input.Venue"></label>
                        <input class="form-control" asp-for="Input.Venue" />
                        <span class="text-danger" asp-validation-for="Input.Venue"></span>
                    </div>
                    <div>
                        <label class="form-label" asp-for="Input.VenueMapLink"></label>
                        <input class="form-control" asp-for="Input.VenueMapLink" type="url" />
                        <span class="text-danger" asp-validation-for="Input.VenueMapLink"></span>
                    </div>
                    <div>
                        <label class="form-label">Pick location</label>
                        <div class="event-map" id="eventMap"></div>
                        <span class="form-text text-muted">Click the map to drop a pin. Drag to adjust the location.</span>
                    </div>
                    <div class="d-flex gap-2">
                        <button class="btn btn-primary" type="submit">Continue</button>
                        <a class="btn btn-outline-secondary" asp-page="/Home/Home">Back</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>
    <script>
        (() => {
            const eventTypeSelect = document.getElementById("Input_EventType");
            const personFields = document.getElementById("personFields");
            const personFields1 = document.getElementById("personFields1");
            const personFields2 = document.getElementById("personFields2");
            const person1Label = document.getElementById("person1Label");
            const person2Label = document.getElementById("person2Label");
            const person1Input = document.getElementById("Input_Person1Name");
            const person2Input = document.getElementById("Input_Person2Name");
            const mapElement = document.getElementById("eventMap");
            const venueMapInput = document.getElementById("Input_VenueMapLink");

            if (!eventTypeSelect || !personFields || !person1Label || !person2Label) {
                return;
            }

            const defaultPerson1Label = person1Label.textContent?.trim() ?? "Person 1 name";
            const defaultPerson2Label = person2Label.textContent?.trim() ?? "Person 2 name";

            const eventTypeConfig = {
                Wedding: { person1Label: "Bride name", person2Label: "Groom name" },
                Engagement: { person1Label: "Fiancée name", person2Label: "Fiancé name" },
                Anniversary: { person1Label: "Husband name", person2Label: "Wife name" },
                BabyShower: { person1Label: "Baby Name", person2Label: "N/A" },
                Birthday: { person1Label: "Name", person2Label: "N/A" },
                Party: { person1Label: "Title", person2Label: "N/A" }
            };

            const updatePersonFields = () => {
                const selectedType = eventTypeSelect.value;
                const config = eventTypeConfig[selectedType];

                if (!config) {
                    personFields.hidden = true;
                    personFields1.hidden = true;
                    personFields2.hidden = true;
                    person1Label.textContent = defaultPerson1Label;
                    person2Label.textContent = defaultPerson2Label;
                    if (person1Input) person1Input.value = "";
                    if (person2Input) person2Input.value = "";
                    return;
                }

                personFields.hidden = false;
                personFields1.hidden = false;
                personFields2.hidden = false;
                person1Label.textContent = config.person1Label;
                person2Label.textContent = config.person2Label;

                if(config.person2Label === "N/A"){
                    personFields2.hidden = true;
                    person2Label.textContent = defaultPerson2Label;
                    if (person2Input) person2Input.value = "";
                }
            };

            eventTypeSelect.addEventListener("change", updatePersonFields);
            updatePersonFields();

            if (!mapElement || !venueMapInput || !window.L) {
                return;
            }

        const map = L.map(mapElement).setView([-34.9285, 138.6007], 4);
            L.tileLayer("https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png", {
                attribution: "&copy; OpenStreetMap contributors"
            }).addTo(map);

            let marker;

            const updateMapLink = (lat, lng) => {
                venueMapInput.value = `https://www.google.com/maps/search/?api=1&query=${lat},${lng}`;
            };

            const placeMarker = (latlng) => {
                if (!marker) {
                    marker = L.marker(latlng, { draggable: true }).addTo(map);
                    marker.on("dragend", () => {
                        const position = marker.getLatLng();
                        updateMapLink(position.lat, position.lng);
                    });
                } else {
                    marker.setLatLng(latlng);
                }

                updateMapLink(latlng.lat, latlng.lng);
            };

            map.on("click", (event) => {
                placeMarker(event.latlng);
            });
        })();
    </script>
}
