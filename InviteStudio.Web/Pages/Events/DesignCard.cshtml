@page "{id:guid}"
@model InviteStudio.Web.Pages.Events.DesignCardModel
@{
    ViewData["Title"] = "Design card";
    var previewModel = Model.TemplateModel;
    var selectedTemplate = Model.TemplatePartialName;
    var inviteUrl = Url.Page("/Events/Invitation", null, new { id = Model.Event?.Id }, Request.Scheme, Request.Host.Value);
}

<div class="event-detail-hero">
    <div class="container">
        <nav class="event-detail-menu">
            <a class="event-detail-menu-link" asp-page="/Events/Details" asp-route-id="@Model.Event?.Id">General</a>
            <a class="event-detail-menu-link is-active" href="#">Invitation design</a>
            <a class="event-detail-menu-link" asp-page="/Events/Guests" asp-route-id="@Model.Event?.Id">Guests</a>
        </nav>
        <div class="event-detail-header">
            <div>
                <span class="event-detail-eyebrow">Design card</span>
                <h1>@previewModel.Title</h1>
                <p class="event-detail-subtitle">@previewModel.Subtitle</p>
            </div>
            <div class="event-detail-actions">
                <button class="btn btn-primary" type="submit" form="designForm">Save changes</button>
                <a class="btn btn-outline-primary btn-action-shape" asp-page="/Home/Home">Back to home</a>
                <button id="copyInviteLink" class="btn btn-outline-secondary" type="button" data-invite-url="@inviteUrl" aria-label="Copy invitation link">Copy invite link</button>
                <script>
                    (function(){
                        const btn = document.getElementById('copyInviteLink');
                        if(!btn) return;
                        btn.addEventListener('click', async function(){
                            const url = this.getAttribute('data-invite-url');
                            try{
                                await navigator.clipboard.writeText(url);
                                const orig = this.innerText;
                                this.innerText = 'Copied';
                                setTimeout(()=> this.innerText = orig, 2000);
                            }catch(e){
                                alert('Failed to copy link');
                            }
                        });
                    })();
                </script>
            </div>
        </div>
    </div>
</div>

<form method="post" id="designForm">
    <input type="hidden" asp-for="Input.EventId" />
    <input type="hidden" asp-for="Input.TimelineJson" id="timelineJson" />
    <input type="hidden" asp-for="Input.AccentColor" id="accentColor" />
    <input type="hidden" asp-for="Input.BackgroundColor" id="backgroundColor" />
    <div class="container pb-5">
        <div class="row g-4">
        <div class="col-12 col-lg-7">
            <section class="event-detail-card">
                <div class="event-detail-section">
                    <div>
                        <span class="event-detail-label">Event details</span>
                        <h2>Card content</h2>
                    </div>
                </div>
                <div class="event-design-grid" id="cardContent" data-event-type="@Model.Event?.EventType" data-event-type-label="@previewModel.EventTypeLabel">
                    <div id="personField1">
                        <label class="form-label" id="person1Label" for="cardPerson1">Person 1 name</label>
                        <input class="form-control" id="cardPerson1" asp-for="Input.Person1Name" value="@previewModel.Person1Name" />
                    </div>
                    <div id="personField2">
                        <label class="form-label" id="person2Label" for="cardPerson2">Person 2 name</label>
                        <input class="form-control" id="cardPerson2" asp-for="Input.Person2Name" value="@previewModel.Person2Name" />
                    </div>
                    <div>
                        <label class="form-label" for="cardMessage">Message</label>
                        <textarea class="form-control" id="cardMessage" rows="4">@previewModel.Message</textarea>
                    </div>
                    <div class="event-design-row">
                        <div>
                            <label class="form-label" for="cardDate">Event date</label>
                            <input class="form-control" id="cardDate" asp-for="Input.EventDate" type="date" value="@Model.Input.EventDate.ToString("yyyy-MM-dd")" />
                        </div>
                    </div>
                </div>
            </section>
            <section class="event-detail-card">
                <div class="event-detail-section">
                    <div>
                        <span class="event-detail-label">Event schedule</span>
                        <h2>Timeline</h2>
                    </div>
                </div>
                <div class="event-design-grid">
                    <div id="scheduleList" class="event-schedule-list"></div>
                    <button class="btn btn-outline-primary" id="addScheduleDate" type="button">Add date</button>
                </div>
            </section>
            <section class="event-detail-card">
                <div class="event-detail-section">
                    <div>
                        <span class="event-detail-label">Location</span>
                        <h2>Venue and Contact</h2>
                    </div>
                </div>
                <div class="event-design-grid">
                    <div>
                        <label class="form-label" for="cardPerson1Phone">Phone number 1</label>
                        <input class="form-control" id="cardPerson1Phone" asp-for="Input.Person1Phone" value="@previewModel.Person1Phone" />
                    </div>
                    <div>
                        <label class="form-label" for="cardPerson2Phone">Phone number 2</label>
                        <input class="form-control" id="cardPerson2Phone" asp-for="Input.Person2Phone" value="@previewModel.Person2Phone" />
                    </div>
                        <div>
                            <label class="form-label" for="cardVenue">Venue</label>
                            <input class="form-control" id="cardVenue" asp-for="Input.Venue" value="@previewModel.Venue" />
                        </div>
                    <div>
                        <label class="form-label" for="locationLink">Venue map link</label>
                        <input class="form-control" id="locationLink" asp-for="Input.VenueMapLink" value="@previewModel.VenueMapLink" readonly />
                    </div>
                    <div>
                        <label class="form-label">Pick location</label>
                        <div class="event-map" id="eventMap"></div>
                        <span class="form-text text-muted">Click the map to drop a pin. Drag to adjust the location.</span>
                    </div>
                    <a class="btn btn-outline-primary btn-sm" id="locationOpenLink" href="#" target="_blank" rel="noopener">Open map</a>
                </div>
            </section>
            <section class="event-detail-card">
                <div class="event-detail-section">
                    <div>
                        <span class="event-detail-label">Media</span>
                        <h2>Video and music</h2>
                    </div>
                </div>
                <div class="event-design-grid">
                    <div>
                        <label class="form-label" for="cardVideoLink">Video link</label>
                        <input class="form-control" id="cardVideoLink" asp-for="Input.VideoLink" value="@previewModel.VideoLink" placeholder="YouTube, Google Drive, OneDrive" />
                    </div>
                    <div>
                        <label class="form-label" for="cardMusicLink">Music link</label>
                        <input class="form-control" id="cardMusicLink" asp-for="Input.MusicLink" value="@previewModel.MusicLink" placeholder="YouTube, Google Drive, OneDrive" />
                    </div>
                </div>
            </section>
            <section class="event-detail-card">
                <div class="event-detail-section">
                    <div>
                        <span class="event-detail-label">Design style</span>
                        <h2>Visual settings</h2>
                    </div>
                </div>
                <div class="event-design-grid">
                    <div>
                        <label class="form-label" for="templateSelect">Template</label>
                        <select class="form-select" id="templateSelect" asp-for="Input.TemplateName">
                            @foreach (var option in Model.TemplateOptions)
                            {
                                <option value="@option.Value">@option.Label</option>
                            }
                        </select>
                    </div>
                    <div>
                        <label class="form-label" for="paletteSwatches">Color palette</label>
                        <div class="event-palette" id="paletteSwatches">
                            <button class="event-palette-swatch is-active" type="button" data-accent="#1f8cff" data-background="#ffffff" style="--swatch-accent: #1f8cff; --swatch-bg: #ffffff;"></button>
                            <button class="event-palette-swatch" type="button" data-accent="#2563eb" data-background="#eff6ff" style="--swatch-accent: #2563eb; --swatch-bg: #eff6ff;"></button>
                            <button class="event-palette-swatch" type="button" data-accent="#14b8a6" data-background="#ecfeff" style="--swatch-accent: #14b8a6; --swatch-bg: #ecfeff;"></button>
                            <button class="event-palette-swatch" type="button" data-accent="#0f766e" data-background="#f0fdfa" style="--swatch-accent: #0f766e; --swatch-bg: #f0fdfa;"></button>
                            <button class="event-palette-swatch" type="button" data-accent="#10b981" data-background="#ecfdf5" style="--swatch-accent: #10b981; --swatch-bg: #ecfdf5;"></button>
                            <button class="event-palette-swatch" type="button" data-accent="#84cc16" data-background="#f7fee7" style="--swatch-accent: #84cc16; --swatch-bg: #f7fee7;"></button>
                            <button class="event-palette-swatch" type="button" data-accent="#f97316" data-background="#fff7e8" style="--swatch-accent: #f97316; --swatch-bg: #fff7e8;"></button>
                            <button class="event-palette-swatch" type="button" data-accent="#ea580c" data-background="#fff1e6" style="--swatch-accent: #ea580c; --swatch-bg: #fff1e6;"></button>
                            <button class="event-palette-swatch" type="button" data-accent="#f59e0b" data-background="#fffbeb" style="--swatch-accent: #f59e0b; --swatch-bg: #fffbeb;"></button>
                            <button class="event-palette-swatch" type="button" data-accent="#e11d48" data-background="#fff1f2" style="--swatch-accent: #e11d48; --swatch-bg: #fff1f2;"></button>
                            <button class="event-palette-swatch" type="button" data-accent="#db2777" data-background="#fdf2f8" style="--swatch-accent: #db2777; --swatch-bg: #fdf2f8;"></button>
                            <button class="event-palette-swatch" type="button" data-accent="#8b5cf6" data-background="#f8f2ff" style="--swatch-accent: #8b5cf6; --swatch-bg: #f8f2ff;"></button>
                            <button class="event-palette-swatch" type="button" data-accent="#6366f1" data-background="#eef2ff" style="--swatch-accent: #6366f1; --swatch-bg: #eef2ff;"></button>
                            <button class="event-palette-swatch" type="button" data-accent="#4f46e5" data-background="#eef2ff" style="--swatch-accent: #4f46e5; --swatch-bg: #eef2ff;"></button>
                            <button class="event-palette-swatch" type="button" data-accent="#0ea5e9" data-background="#f0f9ff" style="--swatch-accent: #0ea5e9; --swatch-bg: #f0f9ff;"></button>
                        </div>
                    </div>
                    <div>
                        <label class="form-label" for="fontStyle">Font style</label>
                        <select class="form-select" id="fontStyle" asp-for="Input.FontFamily">
                            <option value="'Segoe UI', sans-serif">Modern sans</option>
                            <option value="'Playfair Display', serif">Classic serif</option>
                            <option value="'Caveat', cursive">Handwritten</option>
                        </select>
                    </div>
                    <div>
                        <label class="form-label" for="layoutStyle">Layout</label>
                        <select class="form-select" id="layoutStyle" asp-for="Input.LayoutStyle">
                            <option value="center">Centered</option>
                            <option value="split">Split header</option>
                        </select>
                    </div>
                </div>
            </section>
        </div>
        <div class="col-12 col-lg-5">
            <section class="event-detail-card event-preview-card">
                <div class="event-detail-section">
                    <div>
                        <span class="event-detail-label">Live preview</span>
                        <h2>Digital invitation</h2>
                    </div>
                    <span class="event-detail-chip">Preview</span>
                </div>
                <div id="previewContainer">
                    <partial name="~/Pages/Events/Templates/@(Model.TemplatePartialName).cshtml" model="previewModel" />
                </div>
            </section>
        </div>
        </div>
    </div>
</form>

@section Scripts {
    @foreach (var asset in Model.TemplateAssets)
    {
        <link rel="stylesheet" href="~/css/templates/@(asset).css" asp-append-version="true" />
    }
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>
    @foreach (var asset in Model.TemplateAssets)
    {
        <script src="~/js/templates/@(asset).js" asp-append-version="true"></script>
    }
    <script>
        (() => {
            const contentContainer = document.getElementById("cardContent");
            const personField1 = document.getElementById("personField1");
            const personField2 = document.getElementById("personField2");
            const person1Label = document.getElementById("person1Label");
            const person2Label = document.getElementById("person2Label");
            const person1Input = document.getElementById("cardPerson1");
            const person2Input = document.getElementById("cardPerson2");
            const person1PhoneInput = document.getElementById("cardPerson1Phone");
            const person2PhoneInput = document.getElementById("cardPerson2Phone");
            const messageInput = document.getElementById("cardMessage");
            const dateInput = document.getElementById("cardDate");
            const venueInput = document.getElementById("cardVenue");
            const videoLinkInput = document.getElementById("cardVideoLink");
            const musicLinkInput = document.getElementById("cardMusicLink");
            const templateInput = document.getElementById("templateSelect");
            const paletteSwatches = document.getElementById("paletteSwatches");
            const accentColorInput = document.getElementById("accentColor");
            const backgroundColorInput = document.getElementById("backgroundColor");
            const accentState = { value: "@previewModel.AccentColor" };
            const backgroundState = { value: "@previewModel.BackgroundColor" };
            const fontInput = document.getElementById("fontStyle");
            const layoutInput = document.getElementById("layoutStyle");
            const scheduleList = document.getElementById("scheduleList");
            const addScheduleDateButton = document.getElementById("addScheduleDate");
            const timelineJsonInput = document.getElementById("timelineJson");
            const initialTimelineJson = timelineJsonInput?.value ?? "";
            let isHydratingTimeline = true;
            const locationLink = document.getElementById("locationLink");
            const locationOpenLink = document.getElementById("locationOpenLink");
            const mapElement = document.getElementById("eventMap");
            const previewContainer = document.getElementById("previewContainer");

            const getPreviewElements = () => ({
                preview: document.getElementById("invitePreview"),
                previewHeader: document.getElementById("previewHeader"),
                previewTitle: document.getElementById("previewTitle"),
                previewSubtitle: document.getElementById("previewSubtitle"),
                previewMessage: document.getElementById("previewMessage"),
                previewDate: document.getElementById("previewDate"),
                previewVenue: document.getElementById("previewVenue"),
                previewMeta: document.getElementById("previewMeta"),
                previewAccent: document.getElementById("previewAccent"),
                previewPhone1: document.getElementById("previewPhone1"),
                previewPhone2: document.getElementById("previewPhone2"),
                previewVideo: document.getElementById("previewVideo"),
                previewAudio: document.getElementById("previewAudio"),
                previewVideoWrapper: document.getElementById("previewVideoWrapper"),
                previewAudioWrapper: document.getElementById("previewAudioWrapper"),
                previewTimelineWrapper: document.getElementById("previewTimelineWrapper"),
                previewTimeline: document.getElementById("previewTimeline")
            });

            const buildPreviewTitle = () => {
                const person1 = person1Input?.value.trim();
                const person2 = person2Input?.value.trim();

                if (person1 && person2) {
                    return `${person1} & ${person2}`;
                }

                if (person1) {
                    return person1;
                }

                return contentContainer?.dataset.eventTypeLabel || "Invitation";
            };

            const setAudioButtonState = (button, isPlaying) => {
                button.dataset.audioState = isPlaying ? "playing" : "paused";
                button.setAttribute("aria-label", isPlaying ? "Pause music" : "Play music");
                button.classList.toggle("is-playing", isPlaying);
            };

            const updateAudioControls = () => {
                document.querySelectorAll("[data-audio-toggle]").forEach((button) => {
                    button.addEventListener("click", (event) => {
                        event.stopPropagation();
                        const wrapper = button.closest(".event-preview-audio");
                        const audio = wrapper?.querySelector("audio");
                        const iframe = wrapper?.querySelector("iframe");
                        if (!audio) {
                            if (iframe) {
                                const src = iframe.getAttribute("src");
                                const mutedSrc = iframe.dataset.audioMuted;
                                const unmutedSrc = iframe.dataset.audioUnmuted;
                                if (src && unmutedSrc && src === unmutedSrc) {
                                    iframe.setAttribute("src", mutedSrc || "");
                                    setAudioButtonState(button, false);
                                } else {
                                    iframe.setAttribute("src", unmutedSrc || mutedSrc || "");
                                    setAudioButtonState(button, true);
                                }
                            }
                            return;
                        }

                        if (audio.paused) {
                            audio.play().catch(() => {
                            });
                            setAudioButtonState(button, true);
                        } else {
                            audio.pause();
                            setAudioButtonState(button, false);
                        }
                    });

                    const wrapper = button.closest(".event-preview-audio");
                    const audio = wrapper?.querySelector("audio");
                    const iframe = wrapper?.querySelector("iframe");
                    if (audio?.dataset.audioAutoplay === "true") {
                        audio.play().then(() => {
                            setAudioButtonState(button, true);
                        }).catch(() => {
                            setAudioButtonState(button, false);
                        });
                    }

                    if (iframe && iframe.getAttribute("src")) {
                        iframe.dataset.audioMuted = iframe.getAttribute("src") ?? "";
                        if (!iframe.dataset.audioUnmuted) {
                            iframe.dataset.audioUnmuted = iframe.dataset.audioMuted;
                        }
                    }

                    if (!button.dataset.audioState) {
                        const current = iframe?.getAttribute("src") ?? "";
                        const unmuted = iframe?.dataset.audioUnmuted ?? "";
                        setAudioButtonState(button, current !== "" && current === unmuted);
                    }
                });
            };

            const buildPreviewSubtitle = () => {
                const dateText = dateInput?.value.trim();
                const eventLabel = contentContainer?.dataset.eventTypeLabel || "Event";

                if (dateText) {
                    return `${eventLabel} · ${dateText}`;
                }

                return eventLabel;
            };

            const formatDateDisplay = (value) => {
                if (!value) {
                    return "";
                }

                const parsed = new Date(value);
                if (Number.isNaN(parsed.getTime())) {
                    return value;
                }

                return parsed.toLocaleDateString("en-US", { month: "long", day: "2-digit", year: "numeric" });
            };

            const buildEmbedLink = (link) => {
                if (!link) {
                    return "";
                }

                try {
                    const url = new URL(link);
                    if (url.hostname.includes("youtu.be")) {
                        const id = url.pathname.replace("/", "");
                        return id ? `https://www.youtube.com/embed/${id}` : link;
                    }

                    if (url.hostname.includes("youtube.com")) {
                        const id = url.searchParams.get("v");
                        if (id) {
                            return `https://www.youtube.com/embed/${id}`;
                        }

                        const segments = url.pathname.split("/").filter(Boolean);
                        const embedIndex = segments.indexOf("embed");
                        if (embedIndex >= 0 && segments.length > embedIndex + 1) {
                            return `https://www.youtube.com/embed/${segments[embedIndex + 1]}`;
                        }
                    }

                    if (url.hostname.includes("drive.google.com")) {
                        const segments = url.pathname.split("/").filter(Boolean);
                        const fileIndex = segments.indexOf("d");
                        if (fileIndex >= 0 && segments.length > fileIndex + 1) {
                            return `https://drive.google.com/file/d/${segments[fileIndex + 1]}/preview`;
                        }
                    }
                } catch {
                    return link;
                }

                return link;
            };

            const buildMusicEmbedLink = (link, muted) => {
                const embed = buildEmbedLink(link);
                if (!embed || !embed.includes("youtube.com/embed")) {
                    return embed;
                }

                const id = embed.split("/").pop()?.split("?")[0];
                const separator = embed.includes("?") ? "&" : "?";
                const mutedValue = muted ? "1" : "0";
                return `${embed}${separator}autoplay=1&mute=${mutedValue}&controls=0&loop=1&playlist=${id}&enablejsapi=1&playsinline=1`;
            };

            const getMusicType = (link) => {
                if (!link) {
                    return "";
                }

                try {
                    const url = new URL(link);
                    if (url.hostname.includes("youtube.com") || url.hostname.includes("youtu.be")) {
                        return "youtube";
                    }
                } catch {
                    return "audio";
                }

                return "audio";
            };

            const updatePreviewTimeline = (previewTimeline, previewTimelineWrapper) => {
                if (!previewTimeline || !previewTimelineWrapper || !scheduleList) {
                    return;
                }

                previewTimeline.innerHTML = "";
                const groups = [...scheduleList.querySelectorAll(".event-schedule-card")];
                let hasItems = false;

                groups.forEach((group) => {
                    const dateInput = group.querySelector("input[type='date']");
                    const items = [...group.querySelectorAll(".event-schedule-item")];
                    const validItems = items
                        .map((item) => {
                            const timeValue = item.querySelector("input[type='time']")?.value.trim() ?? "";
                            const titleValue = item.querySelector("input[type='text']")?.value.trim() ?? "";
                            return { timeValue, titleValue };
                        })
                        .filter((item) => item.timeValue || item.titleValue);

                    if (validItems.length === 0 && !(dateInput?.value.trim() ?? "")) {
                        return;
                    }

                    hasItems = hasItems || validItems.length > 0;

                    const groupElement = document.createElement("div");
                    groupElement.className = "event-preview-timeline-group";

                    if (dateInput?.value) {
                        const dateLabel = document.createElement("span");
                        dateLabel.className = "event-preview-timeline-date";
                        dateLabel.textContent = formatDateDisplay(dateInput.value);
                        groupElement.appendChild(dateLabel);
                    }

                    validItems.forEach((item) => {
                        const row = document.createElement("div");
                        row.className = "event-preview-timeline-item";

                        if (item.timeValue) {
                            const time = document.createElement("span");
                            time.className = "event-preview-timeline-time";
                            time.textContent = item.timeValue;
                            row.appendChild(time);
                        }

                        if (item.titleValue) {
                            const title = document.createElement("span");
                            title.className = "event-preview-timeline-title";
                            title.textContent = item.titleValue;
                            row.appendChild(title);
                        }

                        groupElement.appendChild(row);
                    });

                    previewTimeline.appendChild(groupElement);
                });

                previewTimelineWrapper.hidden = !hasItems;
                if (timelineJsonInput && !isHydratingTimeline) {
                    timelineJsonInput.value = JSON.stringify(buildSchedulePayload());
                }
            };

            const buildSchedulePayload = () => {
                if (!scheduleList) {
                    return [];
                }

                return [...scheduleList.querySelectorAll(".event-schedule-card")].map((group) => {
                    const dateInput = group.querySelector("input[type='date']");
                    const dateId = group.dataset.scheduleId || crypto.randomUUID();
                    group.dataset.scheduleId = dateId;
                    const items = [...group.querySelectorAll(".event-schedule-item")].map((item) => {
                        const itemId = item.dataset.scheduleItemId || crypto.randomUUID();
                        item.dataset.scheduleItemId = itemId;
                        return {
                            id: itemId,
                            time: item.querySelector("input[type='time']")?.value ?? "",
                            title: item.querySelector("input[type='text']")?.value ?? ""
                        };
                    });

                    return {
                        id: dateId,
                        date: dateInput?.value ?? "",
                        items
                    };
                });
            };

            const updatePreview = () => {
                const {
                    preview,
                    previewHeader,
                    previewTitle,
                    previewSubtitle,
                    previewMessage,
                    previewDate,
                    previewVenue,
                    previewMeta,
                    previewAccent,
                    previewPhone1,
                    previewPhone2,
                    previewVideo,
                    previewAudio,
                    previewVideoWrapper,
                    previewAudioWrapper,
                    previewTimelineWrapper,
                    previewTimeline
                } = getPreviewElements();

                if (!preview || !previewTitle || !previewSubtitle || !previewMessage || !previewDate || !previewVenue || !previewMeta) {
                    return;
                }

                previewTitle.textContent = buildPreviewTitle();
                previewSubtitle.textContent = buildPreviewSubtitle();
                previewMessage.textContent = messageInput?.value.trim() || "";
                previewDate.textContent = formatDateDisplay(dateInput?.value.trim());
                previewVenue.textContent = venueInput?.value.trim() || "";

                if (previewPhone1) {
                    previewPhone1.textContent = person1PhoneInput?.value.trim() || "";
                    previewPhone1.closest(".event-preview-contact")?.classList.toggle("is-empty", !previewPhone1.textContent);
                }

                if (previewPhone2) {
                    previewPhone2.textContent = person2PhoneInput?.value.trim() || "";
                    previewPhone2.closest(".event-preview-contact")?.classList.toggle("is-empty", !previewPhone2.textContent);
                }

                const videoValue = videoLinkInput?.value.trim() || "";
                const musicValue = musicLinkInput?.value.trim() || "";

                const videoEmbed = buildEmbedLink(videoValue);
                const musicEmbedMuted = buildMusicEmbedLink(musicValue, true);
                const musicEmbedUnmuted = buildMusicEmbedLink(musicValue, false);
                const musicType = getMusicType(musicValue);

                if (previewVideoWrapper) {
                    previewVideoWrapper.hidden = !videoEmbed;
                }
                if (previewAudioWrapper) {
                    previewAudioWrapper.hidden = !musicValue;
                }

                if (previewVideo) {
                    previewVideo.src = videoEmbed || "";
                }
                if (previewAudio) {
                    if (musicType === "youtube") {
                        previewAudio.src = musicEmbedMuted || "";
                        previewAudio.dataset.audioMuted = musicEmbedMuted || "";
                        previewAudio.dataset.audioUnmuted = musicEmbedUnmuted || "";
                    } else {
                        previewAudio.src = musicValue || "";
                    }
                }

                const audioEmbed = previewAudioWrapper?.querySelector("[data-audio-embed]");
                if (audioEmbed) {
                    audioEmbed.hidden = musicType !== "youtube";
                }

                const audioIframe = previewAudioWrapper?.querySelector("iframe");
                if (audioIframe) {
                    audioIframe.dataset.src = audioIframe.getAttribute("src") ?? "";
                }

                if (previewAudio && musicType !== "youtube" && !musicValue) {
                    previewAudio.pause();
                }

                if (previewAccent) {
                    previewAccent.style.color = accentState.value;
                }

                if (previewHeader) {
                    previewHeader.style.color = accentState.value;
                }

                const previewEyebrow = previewHeader?.querySelector(".event-preview-eyebrow");
                if (previewEyebrow) {
                    previewEyebrow.style.color = accentState.value;
                }

                if (preview) {
                    preview.style.background = backgroundState.value;
                }

                if (preview && fontInput) {
                    preview.style.fontFamily = fontInput.value;
                }

                if (previewMeta) {
                    previewMeta.style.justifyContent = layoutInput?.value === "split" ? "space-between" : "center";
                }

                updatePreviewTimeline(previewTimeline, previewTimelineWrapper);
            };

            const updateTemplate = async () => {
                if (!templateInput) {
                    return;
                }

                const response = await fetch(`?handler=Template&id=${encodeURIComponent("@Model.Event?.Id")}&template=${encodeURIComponent(templateInput.value)}`);
                if (!response.ok) {
                    return;
                }

                const html = await response.text();
                if (previewContainer) {
                    previewContainer.innerHTML = html;
                    updatePreview();
                    updateAudioControls();
                }
            };

            [person1Input, person2Input, person1PhoneInput, person2PhoneInput, messageInput, dateInput, venueInput, videoLinkInput, musicLinkInput, fontInput, layoutInput].forEach((input) => {
                if (!input) {
                    return;
                }

                input.addEventListener("input", updatePreview);
                input.addEventListener("change", updatePreview);
            });

            if (templateInput) {
                templateInput.addEventListener("change", updateTemplate);
            }

            const defaultPerson1Label = person1Label?.textContent?.trim() ?? "Person 1 name";
            const defaultPerson2Label = person2Label?.textContent?.trim() ?? "Person 2 name";

            const eventTypeConfig = {
                Wedding: { person1Label: "Bride name", person2Label: "Groom name" },
                Engagement: { person1Label: "Fiancée name", person2Label: "Fiancé name" },
                Anniversary: { person1Label: "Husband name", person2Label: "Wife name" },
                BabyShower: { person1Label: "Baby name", person2Label: "N/A" },
                Birthday: { person1Label: "Name", person2Label: "N/A" },
                Party: { person1Label: "Title", person2Label: "N/A" }
            };

            const updatePersonFields = () => {
                if (!contentContainer || !personField1 || !personField2 || !person1Label || !person2Label) {
                    return;
                }

                const eventType = contentContainer.dataset.eventType;
                const config = eventType ? eventTypeConfig[eventType] : null;

                if (!config) {
                    personField1.hidden = false;
                    personField2.hidden = false;
                    person1Label.textContent = defaultPerson1Label;
                    person2Label.textContent = defaultPerson2Label;
                    return;
                }

                personField1.hidden = false;
                personField2.hidden = false;
                person1Label.textContent = config.person1Label;
                person2Label.textContent = config.person2Label;

                if (config.person2Label === "N/A") {
                    personField2.hidden = true;
                    person2Label.textContent = defaultPerson2Label;
                    if (person2Input) {
                        person2Input.value = "";
                    }
                }
            };

            const applyPalette = (swatch) => {
                if (!swatch) {
                    return;
                }

                const accent = swatch.dataset.accent;
                const background = swatch.dataset.background;

                if (accent) {
                    accentState.value = accent;
                    if (accentColorInput) {
                        accentColorInput.value = accent;
                    }
                }

                if (background) {
                    backgroundState.value = background;
                    if (backgroundColorInput) {
                        backgroundColorInput.value = background;
                    }
                }

                paletteSwatches?.querySelectorAll(".event-palette-swatch").forEach((button) => {
                    button.classList.toggle("is-active", button === swatch);
                });

                updatePreview();
            };

            if (paletteSwatches) {
                paletteSwatches.addEventListener("click", (event) => {
                    const target = event.target;
                    if (target instanceof HTMLElement && target.classList.contains("event-palette-swatch")) {
                        applyPalette(target);
                    }
                });
            }

            const updateMapLink = (link) => {
                if (!locationLink || !locationOpenLink) {
                    return;
                }

                locationLink.value = link;
                locationOpenLink.href = link || "#";
                locationOpenLink.classList.toggle("disabled", !link);
            };

            const parseMapLink = (link) => {
                if (!link) {
                    return null;
                }

                try {
                    const url = new URL(link);
                    const query = url.searchParams.get("query");
                    if (!query) {
                        return null;
                    }

                    const parts = query.split(",");
                    if (parts.length < 2) {
                        return null;
                    }

                    const lat = Number.parseFloat(parts[0]);
                    const lng = Number.parseFloat(parts[1]);
                    if (Number.isNaN(lat) || Number.isNaN(lng)) {
                        return null;
                    }

                    return { lat, lng };
                } catch {
                    return null;
                }
            };

            if (mapElement && locationLink && window.L) {
                const map = L.map(mapElement).setView([-34.9285, 138.6007], 4);
                L.tileLayer("https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png", {
                    attribution: "&copy; OpenStreetMap contributors"
                }).addTo(map);

                let marker;

                const updateFromLatLng = (latlng) => {
                    const link = `https://www.google.com/maps/search/?api=1&query=${latlng.lat},${latlng.lng}`;
                    updateMapLink(link);
                };

                const placeMarker = (latlng) => {
                    if (!marker) {
                        marker = L.marker(latlng, { draggable: true }).addTo(map);
                        marker.on("dragend", () => {
                            const position = marker.getLatLng();
                            updateFromLatLng(position);
                        });
                    } else {
                        marker.setLatLng(latlng);
                    }

                    updateFromLatLng(latlng);
                };

                map.on("click", (event) => {
                    placeMarker(event.latlng);
                });

                const existingLocation = parseMapLink(locationLink.value);
                if (existingLocation) {
                    placeMarker(existingLocation);
                    map.setView(existingLocation, 12);
                } else if (locationLink.value) {
                    updateMapLink(locationLink.value);
                }
            }

            let draggedScheduleItem = null;
            let isPointerDragging = false;
            const dropIndicator = document.createElement("div");
            dropIndicator.className = "event-schedule-drop";

            const startPointerDrag = (item, event) => {
                if (!item || event.pointerType === "mouse") {
                    return;
                }

                draggedScheduleItem = item;
                isPointerDragging = true;
                item.classList.add("is-dragging", "is-pointer-dragging");
                item.setPointerCapture(event.pointerId);
                event.preventDefault();
            };

            const updatePointerDrag = (event) => {
                if (!isPointerDragging || !draggedScheduleItem) {
                    return;
                }

                const target = document.elementFromPoint(event.clientX, event.clientY);
                const list = target?.closest(".event-schedule-items");
                if (!list) {
                    return;
                }

                event.preventDefault();
                const afterElement = getDragAfterElement(list, event.clientY);
                if (afterElement) {
                    list.insertBefore(dropIndicator, afterElement);
                } else {
                    list.appendChild(dropIndicator);
                }
            };

            const endPointerDrag = (event) => {
                if (!isPointerDragging || !draggedScheduleItem) {
                    return;
                }

                event.preventDefault();
                draggedScheduleItem.releasePointerCapture(event.pointerId);
                draggedScheduleItem.classList.remove("is-dragging", "is-pointer-dragging");

                if (dropIndicator.parentElement) {
                    dropIndicator.parentElement.insertBefore(draggedScheduleItem, dropIndicator);
                    dropIndicator.remove();
                }

                draggedScheduleItem = null;
                isPointerDragging = false;
            };

            const setScheduleItemDraggable = (item) => {
                if (!item) {
                    return;
                }

                item.draggable = true;
                const handle = item.querySelector(".event-schedule-handle");
                if (handle) {
                    handle.addEventListener("pointerdown", (event) => {
                        startPointerDrag(item, event);
                    });
                }

                item.addEventListener("dragstart", (event) => {
                    draggedScheduleItem = item;
                    item.classList.add("is-dragging");
                    event.dataTransfer.effectAllowed = "move";
                    event.dataTransfer.setData("text/plain", "schedule-item");
                });
                item.addEventListener("dragend", () => {
                    item.classList.remove("is-dragging");
                    draggedScheduleItem = null;
                    document.querySelectorAll(".event-schedule-items.is-drop-target").forEach((list) => {
                        list.classList.remove("is-drop-target");
                    });
                });
            };

            const createScheduleItemRow = (list, itemData) => {
                if (!list) {
                    return;
                }

                const row = document.createElement("div");
                row.className = "event-schedule-item";
                row.innerHTML = `
                    <div class="event-schedule-handle" title="Drag to reorder" aria-hidden="true">⋮⋮</div>
                    <div class="event-schedule-input">
                        <label class="form-label">Time</label>
                        <input class="form-control" type="time" />
                    </div>
                    <div class="event-schedule-input">
                        <label class="form-label">Schedule</label>
                        <input class="form-control" type="text" placeholder="Ceremony" />
                    </div>
                    <div class="event-schedule-actions">
                        <button class="btn btn-outline-danger btn-sm" type="button">Remove</button>
                    </div>
                `;

                const timeInput = row.querySelector("input[type='time']");
                const titleInput = row.querySelector("input[type='text']");
                if (timeInput && itemData?.time) {
                    timeInput.value = itemData.time;
                }
                if (titleInput && itemData?.title) {
                    titleInput.value = itemData.title;
                }
                if (itemData?.id) {
                    row.dataset.scheduleItemId = itemData.id;
                }

                row.querySelector("button")?.addEventListener("click", () => {
                    row.remove();
                    updatePreview();
                });

                row.querySelectorAll("input").forEach((input) => {
                    input.addEventListener("input", updatePreview);
                    input.addEventListener("change", updatePreview);
                });

                setScheduleItemDraggable(row);

                list.appendChild(row);
            };

            const createScheduleGroup = (groupData) => {
                if (!scheduleList) {
                    return;
                }

                const group = document.createElement("div");
                group.className = "event-schedule-card";
                group.innerHTML = `
                    <div class="event-schedule-card-header">
                        <div>
                            <label class="form-label">Date</label>
                            <input class="form-control" type="date" />
                        </div>
                        <button class="btn btn-outline-danger btn-sm" type="button" data-action="remove-date">Remove date</button>
                    </div>
                    <div class="event-schedule-items"></div>
                    <button class="btn btn-outline-primary btn-sm event-schedule-add" type="button" data-action="add-item">Add time</button>
                `;

                const itemList = group.querySelector(".event-schedule-items");
                const dateInput = group.querySelector("input[type='date']");
                if (groupData?.id) {
                    group.dataset.scheduleId = groupData.id;
                }
                if (dateInput && groupData?.date) {
                    dateInput.value = groupData.date;
                }
                if (dateInput) {
                    dateInput.addEventListener("input", updatePreview);
                    dateInput.addEventListener("change", updatePreview);
                }
                group.querySelector("[data-action='remove-date']")?.addEventListener("click", () => {
                    group.remove();
                    updatePreview();
                });

                group.querySelector("[data-action='add-item']")?.addEventListener("click", () => {
                    createScheduleItemRow(itemList);
                });

                scheduleList.appendChild(group);
                if (groupData?.items?.length) {
                    groupData.items.forEach((item) => createScheduleItemRow(itemList, item));
                }
                updatePreview();
            };

            if (addScheduleDateButton) {
                addScheduleDateButton.addEventListener("click", createScheduleGroup);
            }

            const getDragAfterElement = (list, y) => {
                const items = [...list.querySelectorAll(".event-schedule-item:not(.is-dragging)")];
                return items.reduce(
                    (closest, child) => {
                        const box = child.getBoundingClientRect();
                        const offset = y - box.top - box.height / 2;
                        if (offset < 0 && offset > closest.offset) {
                            return { offset, element: child };
                        }
                        return closest;
                    },
                    { offset: Number.NEGATIVE_INFINITY, element: null }
                ).element;
            };

            if (scheduleList) {
                scheduleList.addEventListener("dragover", (event) => {
                    if (!draggedScheduleItem) {
                        return;
                    }

                    const list = event.target.closest(".event-schedule-items");
                    if (!list) {
                        return;
                    }

                    event.preventDefault();
                    const afterElement = getDragAfterElement(list, event.clientY);
                    if (afterElement) {
                        list.insertBefore(dropIndicator, afterElement);
                    } else {
                        list.appendChild(dropIndicator);
                    }
                });

                scheduleList.addEventListener("dragleave", (event) => {
                    const list = event.target.closest(".event-schedule-items");
                    if (!list) {
                        return;
                    }

                    if (event.relatedTarget && list.contains(event.relatedTarget)) {
                        return;
                    }

                    if (dropIndicator.parentElement === list) {
                        dropIndicator.remove();
                    }
                });

                scheduleList.addEventListener("drop", (event) => {
                    if (!draggedScheduleItem) {
                        return;
                    }

                    const list = event.target.closest(".event-schedule-items");
                    if (!list) {
                        return;
                    }

                    event.preventDefault();
                    if (dropIndicator.parentElement === list) {
                        list.insertBefore(draggedScheduleItem, dropIndicator);
                        dropIndicator.remove();
                    }
                });
            }

            document.addEventListener("pointermove", updatePointerDrag);
            document.addEventListener("pointerup", endPointerDrag);
            document.addEventListener("pointercancel", endPointerDrag);

            updatePersonFields();
            if (accentColorInput && !accentColorInput.value) {
                accentColorInput.value = accentState.value;
            }
            if (backgroundColorInput && !backgroundColorInput.value) {
                backgroundColorInput.value = backgroundState.value;
            }
            const initialSwatch = paletteSwatches?.querySelector(
                `.event-palette-swatch[data-accent="${accentState.value}"][data-background="${backgroundState.value}"]`
            );
            if (initialSwatch instanceof HTMLElement) {
                applyPalette(initialSwatch);
            }
            updatePreview();
            updateAudioControls();
            updateMapLink(locationLink?.value ?? "");

            if (initialTimelineJson) {
                try {
                    const scheduleData = JSON.parse(initialTimelineJson);
                    if (Array.isArray(scheduleData)) {
                        scheduleData.forEach((group) => createScheduleGroup(group));
                    }
                } catch {
                }
            }

            isHydratingTimeline = false;
            if (timelineJsonInput && !timelineJsonInput.value) {
                timelineJsonInput.value = JSON.stringify(buildSchedulePayload());
            }

            updatePreview();
        })();
    </script>
}
