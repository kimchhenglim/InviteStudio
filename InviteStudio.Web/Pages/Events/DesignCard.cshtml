@page "{id:guid}"
@model InviteStudio.Web.Pages.Events.DesignCardModel
@{
    ViewData["Title"] = "Design card";
}

<div class="event-detail-hero">
    <div class="container">
        <nav class="event-detail-menu">
            <a class="event-detail-menu-link" asp-page="/Events/Details" asp-route-id="@Model.Event?.Id">General</a>
            <a class="event-detail-menu-link is-active" href="#">Design card</a>
            <a class="event-detail-menu-link" href="#">Guests</a>
        </nav>
        <div class="event-detail-header">
            <div>
                <span class="event-detail-eyebrow">Design card</span>
                <h1>@Model.EventTitle</h1>
                <p class="event-detail-subtitle">@Model.EventSubtitle</p>
            </div>
            <div class="event-detail-actions">
                <button class="btn btn-primary" type="button">Save changes</button>
                <a class="btn btn-outline-primary" asp-page="/Events/Details" asp-route-id="@Model.Event?.Id">Back to overview</a>
            </div>
        </div>
    </div>
</div>

<div class="container pb-5">
    <div class="row g-4">
        <div class="col-12 col-lg-7">
            <section class="event-detail-card">
                <div class="event-detail-section">
                    <div>
                        <span class="event-detail-label">Event details</span>
                        <h2>Card content</h2>
                    </div>
                </div>
                <div class="event-design-grid">
                    <div>
                        <label class="form-label" for="cardTitle">Invitation title</label>
                        <input class="form-control" id="cardTitle" value="@Model.EventTitle" />
                    </div>
                    <div>
                        <label class="form-label" for="cardSubtitle">Subtitle</label>
                        <input class="form-control" id="cardSubtitle" value="@Model.EventSubtitle" />
                    </div>
                    <div>
                        <label class="form-label" for="cardMessage">Message</label>
                        <textarea class="form-control" id="cardMessage" rows="4">We would love to celebrate with you. Please join us for our special day.</textarea>
                    </div>
                    <div class="event-design-row">
                        <div>
                            <label class="form-label" for="cardDate">Event date</label>
                            <input class="form-control" id="cardDate" value="@Model.Event?.EventDate.ToString("MMMM dd, yyyy")" />
                        </div>
                        <div>
                            <label class="form-label" for="cardVenue">Venue</label>
                            <input class="form-control" id="cardVenue" value="@Model.Event?.Venue" />
                        </div>
                    </div>
                </div>
            </section>
            <section class="event-detail-card">
                <div class="event-detail-section">
                    <div>
                        <span class="event-detail-label">Design style</span>
                        <h2>Visual settings</h2>
                    </div>
                </div>
                <div class="event-design-grid">
                    <div>
                        <label class="form-label" for="accentColor">Accent color</label>
                        <input class="form-control form-control-color" id="accentColor" type="color" value="#1f8cff" />
                    </div>
                    <div>
                        <label class="form-label" for="backgroundTone">Background tone</label>
                        <select class="form-select" id="backgroundTone">
                            <option value="#ffffff" selected>Soft white</option>
                            <option value="#f8f2ff">Lavender mist</option>
                            <option value="#f0f7ff">Powder blue</option>
                            <option value="#fff7e8">Golden cream</option>
                        </select>
                    </div>
                    <div>
                        <label class="form-label" for="fontStyle">Font style</label>
                        <select class="form-select" id="fontStyle">
                            <option value="'Segoe UI', sans-serif" selected>Modern sans</option>
                            <option value="'Playfair Display', serif">Classic serif</option>
                            <option value="'Caveat', cursive">Handwritten</option>
                        </select>
                    </div>
                    <div>
                        <label class="form-label" for="layoutStyle">Layout</label>
                        <select class="form-select" id="layoutStyle">
                            <option value="center" selected>Centered</option>
                            <option value="split">Split header</option>
                        </select>
                    </div>
                </div>
            </section>
        </div>
        <div class="col-12 col-lg-5">
            <section class="event-detail-card event-preview-card">
                <div class="event-detail-section">
                    <div>
                        <span class="event-detail-label">Live preview</span>
                        <h2>Digital invitation</h2>
                    </div>
                    <span class="event-detail-chip">Preview</span>
                </div>
                <div class="event-preview-shell" id="invitePreview">
                    <div class="event-preview-header" id="previewHeader">
                        <span class="event-preview-eyebrow">You're invited</span>
                        <h3 id="previewTitle">@Model.EventTitle</h3>
                        <p id="previewSubtitle">@Model.EventSubtitle</p>
                    </div>
                    <p class="event-preview-message" id="previewMessage">
                        We would love to celebrate with you. Please join us for our special day.
                    </p>
                    <div class="event-preview-meta" id="previewMeta">
                        <div>
                            <span class="event-preview-label">Date</span>
                            <span id="previewDate">@Model.Event?.EventDate.ToString("MMMM dd, yyyy")</span>
                        </div>
                        <div>
                            <span class="event-preview-label">Location</span>
                            <span id="previewVenue">@Model.Event?.Venue</span>
                        </div>
                    </div>
                    <div class="event-preview-footer">
                        <span>RSVP by April 10</span>
                        <span id="previewAccent">invites.invite.studio</span>
                    </div>
                </div>
            </section>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (() => {
            const titleInput = document.getElementById("cardTitle");
            const subtitleInput = document.getElementById("cardSubtitle");
            const messageInput = document.getElementById("cardMessage");
            const dateInput = document.getElementById("cardDate");
            const venueInput = document.getElementById("cardVenue");
            const accentInput = document.getElementById("accentColor");
            const backgroundInput = document.getElementById("backgroundTone");
            const fontInput = document.getElementById("fontStyle");
            const layoutInput = document.getElementById("layoutStyle");
            const preview = document.getElementById("invitePreview");
            const previewHeader = document.getElementById("previewHeader");
            const previewTitle = document.getElementById("previewTitle");
            const previewSubtitle = document.getElementById("previewSubtitle");
            const previewMessage = document.getElementById("previewMessage");
            const previewDate = document.getElementById("previewDate");
            const previewVenue = document.getElementById("previewVenue");
            const previewMeta = document.getElementById("previewMeta");
            const previewAccent = document.getElementById("previewAccent");

            if (!preview || !previewTitle || !previewSubtitle || !previewMessage || !previewDate || !previewVenue || !previewMeta) {
                return;
            }

            const updatePreview = () => {
                previewTitle.textContent = titleInput?.value.trim() || "Invitation";
                previewSubtitle.textContent = subtitleInput?.value.trim() || "You're invited";
                previewMessage.textContent = messageInput?.value.trim() || "";
                previewDate.textContent = dateInput?.value.trim() || "";
                previewVenue.textContent = venueInput?.value.trim() || "";

                if (previewAccent && accentInput) {
                    previewAccent.style.color = accentInput.value;
                }

                if (previewHeader && accentInput) {
                    previewHeader.style.color = accentInput.value;
                }

                if (preview && backgroundInput) {
                    preview.style.background = backgroundInput.value;
                }

                if (preview && fontInput) {
                    preview.style.fontFamily = fontInput.value;
                }

                if (previewMeta) {
                    previewMeta.style.justifyContent = layoutInput?.value === "split" ? "space-between" : "center";
                }
            };

            [titleInput, subtitleInput, messageInput, dateInput, venueInput, accentInput, backgroundInput, fontInput, layoutInput].forEach((input) => {
                if (!input) {
                    return;
                }

                input.addEventListener("input", updatePreview);
                input.addEventListener("change", updatePreview);
            });

            updatePreview();
        })();
    </script>
}
