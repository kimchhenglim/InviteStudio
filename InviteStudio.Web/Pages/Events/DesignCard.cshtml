@page "{id:guid}"
@model InviteStudio.Web.Pages.Events.DesignCardModel
@{
    ViewData["Title"] = "Design card";
    var previewModel = Model.TemplateModel;
    var selectedTemplate = Model.TemplatePartialName;
}

<div class="event-detail-hero">
    <div class="container">
        <nav class="event-detail-menu">
            <a class="event-detail-menu-link" asp-page="/Events/Details" asp-route-id="@Model.Event?.Id">General</a>
            <a class="event-detail-menu-link is-active" href="#">Invitation design</a>
            <a class="event-detail-menu-link" href="#">Guests</a>
        </nav>
        <div class="event-detail-header">
            <div>
                <span class="event-detail-eyebrow">Design card</span>
                <h1>@previewModel.Title</h1>
                <p class="event-detail-subtitle">@previewModel.Subtitle</p>
            </div>
            <div class="event-detail-actions">
                <button class="btn btn-primary" type="button">Save changes</button>
                <a class="btn btn-outline-primary" asp-page="/Events/Details" asp-route-id="@Model.Event?.Id">Back to overview</a>
            </div>
        </div>
    </div>
</div>

<div class="container pb-5">
    <div class="row g-4">
        <div class="col-12 col-lg-7">
            <section class="event-detail-card">
                <div class="event-detail-section">
                    <div>
                        <span class="event-detail-label">Event details</span>
                        <h2>Card content</h2>
                    </div>
                </div>
                <div class="event-design-grid" id="cardContent" data-event-type="@Model.Event?.EventType" data-event-type-label="@previewModel.EventTypeLabel">
                    <div id="personField1">
                        <label class="form-label" id="person1Label" for="cardPerson1">Person 1 name</label>
                        <input class="form-control" id="cardPerson1" value="@previewModel.Person1Name" />
                    </div>
                    <div id="personField2">
                        <label class="form-label" id="person2Label" for="cardPerson2">Person 2 name</label>
                        <input class="form-control" id="cardPerson2" value="@previewModel.Person2Name" />
                    </div>
                    <div>
                        <label class="form-label" for="cardMessage">Message</label>
                        <textarea class="form-control" id="cardMessage" rows="4">@previewModel.Message</textarea>
                    </div>
                    <div class="event-design-row">
                        <div>
                            <label class="form-label" for="cardDate">Event date</label>
                            <input class="form-control" id="cardDate" value="@previewModel.DateText" />
                        </div>
                        <div>
                            <label class="form-label" for="cardVenue">Venue</label>
                            <input class="form-control" id="cardVenue" value="@previewModel.Venue" />
                        </div>
                    </div>
                </div>
            </section>
            <section class="event-detail-card">
                <div class="event-detail-section">
                    <div>
                        <span class="event-detail-label">Event schedule</span>
                        <h2>Timeline</h2>
                    </div>
                </div>
                <div class="event-design-grid">
                    <div id="scheduleList" class="event-schedule-list"></div>
                    <button class="btn btn-outline-primary" id="addScheduleDate" type="button">Add date</button>
                </div>
            </section>
            <section class="event-detail-card">
                <div class="event-detail-section">
                    <div>
                        <span class="event-detail-label">Location</span>
                        <h2>Venue map</h2>
                    </div>
                </div>
                <div class="event-design-grid">
                    <div>
                        <label class="form-label" for="locationAddress">Address</label>
                        <input class="form-control" id="locationAddress" value="@previewModel.Venue" placeholder="Enter venue address" />
                    </div>
                    <div>
                        <label class="form-label" for="locationLink">Google Maps link</label>
                        <input class="form-control" id="locationLink" readonly />
                    </div>
                    <a class="btn btn-outline-primary btn-sm" id="locationOpenLink" href="#" target="_blank" rel="noopener">Open map</a>
                </div>
            </section>
            <section class="event-detail-card">
                <div class="event-detail-section">
                    <div>
                        <span class="event-detail-label">Design style</span>
                        <h2>Visual settings</h2>
                    </div>
                </div>
                <div class="event-design-grid">
                    <div>
                        <label class="form-label" for="templateSelect">Template</label>
                        <select class="form-select" id="templateSelect">
                            @foreach (var option in Model.TemplateOptions)
                            {
                                <option value="@option.Value" selected="@(option.Value == selectedTemplate)">@option.Label</option>
                            }
                        </select>
                    </div>
                    <div>
                        <label class="form-label" for="paletteSwatches">Color palette</label>
                        <div class="event-palette" id="paletteSwatches">
                            <button class="event-palette-swatch is-active" type="button" data-accent="#1f8cff" data-background="#ffffff" style="--swatch-accent: #1f8cff; --swatch-bg: #ffffff;"></button>
                            <button class="event-palette-swatch" type="button" data-accent="#2563eb" data-background="#eff6ff" style="--swatch-accent: #2563eb; --swatch-bg: #eff6ff;"></button>
                            <button class="event-palette-swatch" type="button" data-accent="#14b8a6" data-background="#ecfeff" style="--swatch-accent: #14b8a6; --swatch-bg: #ecfeff;"></button>
                            <button class="event-palette-swatch" type="button" data-accent="#0f766e" data-background="#f0fdfa" style="--swatch-accent: #0f766e; --swatch-bg: #f0fdfa;"></button>
                            <button class="event-palette-swatch" type="button" data-accent="#10b981" data-background="#ecfdf5" style="--swatch-accent: #10b981; --swatch-bg: #ecfdf5;"></button>
                            <button class="event-palette-swatch" type="button" data-accent="#84cc16" data-background="#f7fee7" style="--swatch-accent: #84cc16; --swatch-bg: #f7fee7;"></button>
                            <button class="event-palette-swatch" type="button" data-accent="#f97316" data-background="#fff7e8" style="--swatch-accent: #f97316; --swatch-bg: #fff7e8;"></button>
                            <button class="event-palette-swatch" type="button" data-accent="#ea580c" data-background="#fff1e6" style="--swatch-accent: #ea580c; --swatch-bg: #fff1e6;"></button>
                            <button class="event-palette-swatch" type="button" data-accent="#f59e0b" data-background="#fffbeb" style="--swatch-accent: #f59e0b; --swatch-bg: #fffbeb;"></button>
                            <button class="event-palette-swatch" type="button" data-accent="#e11d48" data-background="#fff1f2" style="--swatch-accent: #e11d48; --swatch-bg: #fff1f2;"></button>
                            <button class="event-palette-swatch" type="button" data-accent="#db2777" data-background="#fdf2f8" style="--swatch-accent: #db2777; --swatch-bg: #fdf2f8;"></button>
                            <button class="event-palette-swatch" type="button" data-accent="#8b5cf6" data-background="#f8f2ff" style="--swatch-accent: #8b5cf6; --swatch-bg: #f8f2ff;"></button>
                            <button class="event-palette-swatch" type="button" data-accent="#6366f1" data-background="#eef2ff" style="--swatch-accent: #6366f1; --swatch-bg: #eef2ff;"></button>
                            <button class="event-palette-swatch" type="button" data-accent="#4f46e5" data-background="#eef2ff" style="--swatch-accent: #4f46e5; --swatch-bg: #eef2ff;"></button>
                            <button class="event-palette-swatch" type="button" data-accent="#0ea5e9" data-background="#f0f9ff" style="--swatch-accent: #0ea5e9; --swatch-bg: #f0f9ff;"></button>
                        </div>
                    </div>
                    <div>
                        <label class="form-label" for="fontStyle">Font style</label>
                        <select class="form-select" id="fontStyle">
                            <option value="'Segoe UI', sans-serif" selected>Modern sans</option>
                            <option value="'Playfair Display', serif">Classic serif</option>
                            <option value="'Caveat', cursive">Handwritten</option>
                        </select>
                    </div>
                    <div>
                        <label class="form-label" for="layoutStyle">Layout</label>
                        <select class="form-select" id="layoutStyle">
                            <option value="center" selected>Centered</option>
                            <option value="split">Split header</option>
                        </select>
                    </div>
                </div>
            </section>
        </div>
        <div class="col-12 col-lg-5">
            <section class="event-detail-card event-preview-card">
                <div class="event-detail-section">
                    <div>
                        <span class="event-detail-label">Live preview</span>
                        <h2>Digital invitation</h2>
                    </div>
                    <span class="event-detail-chip">Preview</span>
                </div>
                <div id="previewContainer">
                    <partial name="~/Pages/Events/Templates/@(Model.TemplatePartialName).cshtml" model="previewModel" />
                </div>
            </section>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (() => {
            const contentContainer = document.getElementById("cardContent");
            const personField1 = document.getElementById("personField1");
            const personField2 = document.getElementById("personField2");
            const person1Label = document.getElementById("person1Label");
            const person2Label = document.getElementById("person2Label");
            const person1Input = document.getElementById("cardPerson1");
            const person2Input = document.getElementById("cardPerson2");
            const messageInput = document.getElementById("cardMessage");
            const dateInput = document.getElementById("cardDate");
            const venueInput = document.getElementById("cardVenue");
            const templateInput = document.getElementById("templateSelect");
            const paletteSwatches = document.getElementById("paletteSwatches");
            const accentState = { value: "@previewModel.AccentColor" };
            const backgroundState = { value: "@previewModel.BackgroundColor" };
            const fontInput = document.getElementById("fontStyle");
            const layoutInput = document.getElementById("layoutStyle");
            const scheduleList = document.getElementById("scheduleList");
            const addScheduleDateButton = document.getElementById("addScheduleDate");
            const locationAddress = document.getElementById("locationAddress");
            const locationLink = document.getElementById("locationLink");
            const locationOpenLink = document.getElementById("locationOpenLink");
            const previewContainer = document.getElementById("previewContainer");

            const getPreviewElements = () => ({
                preview: document.getElementById("invitePreview"),
                previewHeader: document.getElementById("previewHeader"),
                previewTitle: document.getElementById("previewTitle"),
                previewSubtitle: document.getElementById("previewSubtitle"),
                previewMessage: document.getElementById("previewMessage"),
                previewDate: document.getElementById("previewDate"),
                previewVenue: document.getElementById("previewVenue"),
                previewMeta: document.getElementById("previewMeta"),
                previewAccent: document.getElementById("previewAccent")
            });

            const buildPreviewTitle = () => {
                const person1 = person1Input?.value.trim();
                const person2 = person2Input?.value.trim();

                if (person1 && person2) {
                    return `${person1} & ${person2}`;
                }

                if (person1) {
                    return person1;
                }

                return contentContainer?.dataset.eventTypeLabel || "Invitation";
            };

            const buildPreviewSubtitle = () => {
                const dateText = dateInput?.value.trim();
                const eventLabel = contentContainer?.dataset.eventTypeLabel || "Event";

                if (dateText) {
                    return `${eventLabel} · ${dateText}`;
                }

                return eventLabel;
            };

            const updatePreview = () => {
                const { preview, previewHeader, previewTitle, previewSubtitle, previewMessage, previewDate, previewVenue, previewMeta, previewAccent } = getPreviewElements();

                if (!preview || !previewTitle || !previewSubtitle || !previewMessage || !previewDate || !previewVenue || !previewMeta) {
                    return;
                }

                previewTitle.textContent = buildPreviewTitle();
                previewSubtitle.textContent = buildPreviewSubtitle();
                previewMessage.textContent = messageInput?.value.trim() || "";
                previewDate.textContent = dateInput?.value.trim() || "";
                previewVenue.textContent = venueInput?.value.trim() || "";

                if (previewAccent) {
                    previewAccent.style.color = accentState.value;
                }

                if (previewHeader) {
                    previewHeader.style.color = accentState.value;
                }

                const previewEyebrow = previewHeader?.querySelector(".event-preview-eyebrow");
                if (previewEyebrow) {
                    previewEyebrow.style.color = accentState.value;
                }

                if (preview) {
                    preview.style.background = backgroundState.value;
                }

                if (preview && fontInput) {
                    preview.style.fontFamily = fontInput.value;
                }

                if (previewMeta) {
                    previewMeta.style.justifyContent = layoutInput?.value === "split" ? "space-between" : "center";
                }
            };

            const updateTemplate = async () => {
                if (!templateInput) {
                    return;
                }

                const response = await fetch(`?handler=Template&id=${encodeURIComponent("@Model.Event?.Id")}&template=${encodeURIComponent(templateInput.value)}`);
                if (!response.ok) {
                    return;
                }

                const html = await response.text();
                if (previewContainer) {
                    previewContainer.innerHTML = html;
                    updatePreview();
                }
            };

            [person1Input, person2Input, messageInput, dateInput, venueInput, fontInput, layoutInput].forEach((input) => {
                if (!input) {
                    return;
                }

                input.addEventListener("input", updatePreview);
                input.addEventListener("change", updatePreview);
            });

            if (templateInput) {
                templateInput.addEventListener("change", updateTemplate);
            }

            const defaultPerson1Label = person1Label?.textContent?.trim() ?? "Person 1 name";
            const defaultPerson2Label = person2Label?.textContent?.trim() ?? "Person 2 name";

            const eventTypeConfig = {
                Wedding: { person1Label: "Bride name", person2Label: "Groom name" },
                Engagement: { person1Label: "Fiancée name", person2Label: "Fiancé name" },
                Anniversary: { person1Label: "Husband name", person2Label: "Wife name" },
                BabyShower: { person1Label: "Baby name", person2Label: "N/A" },
                Birthday: { person1Label: "Name", person2Label: "N/A" },
                Party: { person1Label: "Title", person2Label: "N/A" }
            };

            const updatePersonFields = () => {
                if (!contentContainer || !personField1 || !personField2 || !person1Label || !person2Label) {
                    return;
                }

                const eventType = contentContainer.dataset.eventType;
                const config = eventType ? eventTypeConfig[eventType] : null;

                if (!config) {
                    personField1.hidden = false;
                    personField2.hidden = false;
                    person1Label.textContent = defaultPerson1Label;
                    person2Label.textContent = defaultPerson2Label;
                    return;
                }

                personField1.hidden = false;
                personField2.hidden = false;
                person1Label.textContent = config.person1Label;
                person2Label.textContent = config.person2Label;

                if (config.person2Label === "N/A") {
                    personField2.hidden = true;
                    person2Label.textContent = defaultPerson2Label;
                    if (person2Input) {
                        person2Input.value = "";
                    }
                }
            };

            const applyPalette = (swatch) => {
                if (!swatch) {
                    return;
                }

                const accent = swatch.dataset.accent;
                const background = swatch.dataset.background;

                if (accent) {
                    accentState.value = accent;
                }

                if (background) {
                    backgroundState.value = background;
                }

                paletteSwatches?.querySelectorAll(".event-palette-swatch").forEach((button) => {
                    button.classList.toggle("is-active", button === swatch);
                });

                updatePreview();
            };

            if (paletteSwatches) {
                paletteSwatches.addEventListener("click", (event) => {
                    const target = event.target;
                    if (target instanceof HTMLElement && target.classList.contains("event-palette-swatch")) {
                        applyPalette(target);
                    }
                });
            }

            const buildMapsLink = (address) => {
                const trimmed = address.trim();
                if (!trimmed) {
                    return "";
                }

                return `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(trimmed)}`;
            };

            const updateMapLink = () => {
                if (!locationAddress || !locationLink || !locationOpenLink) {
                    return;
                }

                const link = buildMapsLink(locationAddress.value);
                locationLink.value = link;
                locationOpenLink.href = link || "#";
                locationOpenLink.classList.toggle("disabled", !link);
            };

            if (locationAddress) {
                locationAddress.addEventListener("input", updateMapLink);
            }

            let draggedScheduleItem = null;
            let isPointerDragging = false;
            const dropIndicator = document.createElement("div");
            dropIndicator.className = "event-schedule-drop";

            const startPointerDrag = (item, event) => {
                if (!item || event.pointerType === "mouse") {
                    return;
                }

                draggedScheduleItem = item;
                isPointerDragging = true;
                item.classList.add("is-dragging", "is-pointer-dragging");
                item.setPointerCapture(event.pointerId);
                event.preventDefault();
            };

            const updatePointerDrag = (event) => {
                if (!isPointerDragging || !draggedScheduleItem) {
                    return;
                }

                const target = document.elementFromPoint(event.clientX, event.clientY);
                const list = target?.closest(".event-schedule-items");
                if (!list) {
                    return;
                }

                event.preventDefault();
                const afterElement = getDragAfterElement(list, event.clientY);
                if (afterElement) {
                    list.insertBefore(dropIndicator, afterElement);
                } else {
                    list.appendChild(dropIndicator);
                }
            };

            const endPointerDrag = (event) => {
                if (!isPointerDragging || !draggedScheduleItem) {
                    return;
                }

                event.preventDefault();
                draggedScheduleItem.releasePointerCapture(event.pointerId);
                draggedScheduleItem.classList.remove("is-dragging", "is-pointer-dragging");

                if (dropIndicator.parentElement) {
                    dropIndicator.parentElement.insertBefore(draggedScheduleItem, dropIndicator);
                    dropIndicator.remove();
                }

                draggedScheduleItem = null;
                isPointerDragging = false;
            };

            const setScheduleItemDraggable = (item) => {
                if (!item) {
                    return;
                }

                item.draggable = true;
                const handle = item.querySelector(".event-schedule-handle");
                if (handle) {
                    handle.addEventListener("pointerdown", (event) => {
                        startPointerDrag(item, event);
                    });
                }

                item.addEventListener("dragstart", (event) => {
                    draggedScheduleItem = item;
                    item.classList.add("is-dragging");
                    event.dataTransfer.effectAllowed = "move";
                    event.dataTransfer.setData("text/plain", "schedule-item");
                });
                item.addEventListener("dragend", () => {
                    item.classList.remove("is-dragging");
                    draggedScheduleItem = null;
                    document.querySelectorAll(".event-schedule-items.is-drop-target").forEach((list) => {
                        list.classList.remove("is-drop-target");
                    });
                });
            };

            const createScheduleItemRow = (list) => {
                if (!list) {
                    return;
                }

                const row = document.createElement("div");
                row.className = "event-schedule-item";
                row.innerHTML = `
                    <div class="event-schedule-handle" title="Drag to reorder" aria-hidden="true">⋮⋮</div>
                    <div class="event-schedule-input">
                        <label class="form-label">Time</label>
                        <input class="form-control" type="time" />
                    </div>
                    <div class="event-schedule-input">
                        <label class="form-label">Schedule</label>
                        <input class="form-control" type="text" placeholder="Ceremony" />
                    </div>
                    <div class="event-schedule-actions">
                        <button class="btn btn-outline-danger btn-sm" type="button">Remove</button>
                    </div>
                `;

                row.querySelector("button")?.addEventListener("click", () => {
                    row.remove();
                });

                setScheduleItemDraggable(row);

                list.appendChild(row);
            };

            const createScheduleGroup = () => {
                if (!scheduleList) {
                    return;
                }

                const group = document.createElement("div");
                group.className = "event-schedule-card";
                group.innerHTML = `
                    <div class="event-schedule-card-header">
                        <div>
                            <label class="form-label">Date</label>
                            <input class="form-control" type="date" />
                        </div>
                        <button class="btn btn-outline-danger btn-sm" type="button" data-action="remove-date">Remove date</button>
                    </div>
                    <div class="event-schedule-items"></div>
                    <button class="btn btn-outline-primary btn-sm event-schedule-add" type="button" data-action="add-item">Add time</button>
                `;

                const itemList = group.querySelector(".event-schedule-items");
                group.querySelector("[data-action='remove-date']")?.addEventListener("click", () => {
                    group.remove();
                });

                group.querySelector("[data-action='add-item']")?.addEventListener("click", () => {
                    createScheduleItemRow(itemList);
                });

                createScheduleItemRow(itemList);
                scheduleList.appendChild(group);
            };

            if (addScheduleDateButton) {
                addScheduleDateButton.addEventListener("click", createScheduleGroup);
            }

            const getDragAfterElement = (list, y) => {
                const items = [...list.querySelectorAll(".event-schedule-item:not(.is-dragging)")];
                return items.reduce(
                    (closest, child) => {
                        const box = child.getBoundingClientRect();
                        const offset = y - box.top - box.height / 2;
                        if (offset < 0 && offset > closest.offset) {
                            return { offset, element: child };
                        }
                        return closest;
                    },
                    { offset: Number.NEGATIVE_INFINITY, element: null }
                ).element;
            };

            if (scheduleList) {
                scheduleList.addEventListener("dragover", (event) => {
                    if (!draggedScheduleItem) {
                        return;
                    }

                    const list = event.target.closest(".event-schedule-items");
                    if (!list) {
                        return;
                    }

                    event.preventDefault();
                    const afterElement = getDragAfterElement(list, event.clientY);
                    if (afterElement) {
                        list.insertBefore(dropIndicator, afterElement);
                    } else {
                        list.appendChild(dropIndicator);
                    }
                });

                scheduleList.addEventListener("dragleave", (event) => {
                    const list = event.target.closest(".event-schedule-items");
                    if (!list) {
                        return;
                    }

                    if (event.relatedTarget && list.contains(event.relatedTarget)) {
                        return;
                    }

                    if (dropIndicator.parentElement === list) {
                        dropIndicator.remove();
                    }
                });

                scheduleList.addEventListener("drop", (event) => {
                    if (!draggedScheduleItem) {
                        return;
                    }

                    const list = event.target.closest(".event-schedule-items");
                    if (!list) {
                        return;
                    }

                    event.preventDefault();
                    if (dropIndicator.parentElement === list) {
                        list.insertBefore(draggedScheduleItem, dropIndicator);
                        dropIndicator.remove();
                    }
                });
            }

            document.addEventListener("pointermove", updatePointerDrag);
            document.addEventListener("pointerup", endPointerDrag);
            document.addEventListener("pointercancel", endPointerDrag);

            updatePersonFields();
            updatePreview();
            updateMapLink();

            if (scheduleList && scheduleList.children.length === 0) {
                createScheduleGroup();
            }
        })();
    </script>
}
