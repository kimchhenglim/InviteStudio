@model InviteStudio.Web.Pages.Events.InvitationTemplateModel

<div class="event-preview-shell invite-template" id="invitePreview" style="background: @Model.BackgroundColor; font-family: @Model.FontFamily;">
    <div class="event-preview-header" id="previewHeader" style="color: @Model.AccentColor;">
        <span class="event-preview-eyebrow">You're invited</span>
        <h3 id="previewTitle">@Model.Title</h3>
        <p id="previewSubtitle">@Model.Subtitle</p>
    </div>
    <p class="event-preview-message" id="previewMessage">@Model.Message</p>
    <div class="event-preview-meta" id="previewMeta" style="justify-content: @(Model.LayoutStyle == "split" ? "space-between" : "center");">
        <div>
            <span class="event-preview-label">Date</span>
            <span id="previewDate">@Model.DateText</span>
        </div>
        <div>
            <span class="event-preview-label">Location</span>
            <span id="previewVenue">@Model.Venue</span>
        </div>
    </div>
    @if (!string.IsNullOrWhiteSpace(Model.VenueMapLink))
    {
        <div class="event-preview-map-row">
            <a class="event-preview-map-link" href="@Model.VenueMapLink" target="_blank" rel="noopener">Open map</a>
        </div>
    }
    <div class="event-preview-contacts">
        <div class="event-preview-contact @(string.IsNullOrWhiteSpace(Model.Person1Phone) ? "is-empty" : "")">
            <span class="event-preview-label">Mobile</span>
            <span id="previewPhone1">@Model.Person1Phone</span>
        </div>
        <div class="event-preview-contact @(string.IsNullOrWhiteSpace(Model.Person2Phone) ? "is-empty" : "")">
            <span class="event-preview-label">Mobile</span>
            <span id="previewPhone2">@Model.Person2Phone</span>
        </div>
    </div>
    <div class="event-preview-media" id="previewVideoWrapper" @(string.IsNullOrWhiteSpace(Model.VideoEmbedLink) ? "hidden" : "")>
        <span class="event-preview-label">Video</span>
        <div class="event-preview-video">
            <iframe id="previewVideo" src="@Model.VideoEmbedLink" title="Event video" allow="autoplay; encrypted-media; picture-in-picture" allowfullscreen></iframe>
        </div>
    </div>
    <div class="event-preview-timeline" id="previewTimelineWrapper" @(Model.Timeline.Groups.Count == 0 ? "hidden" : "")>
        <span class="event-preview-label">Timeline</span>
        <div class="event-preview-timeline-list" id="previewTimeline">
            @foreach (var group in Model.Timeline.Groups)
            {
                <div class="event-preview-timeline-group">
                    @if (DateTime.TryParse(group.Date, out var parsedDate))
                    {
                        <span class="event-preview-timeline-date">@parsedDate.ToString("MMMM dd, yyyy")</span>
                    }
                    @foreach (var item in group.Items)
                    {
                        <div class="event-preview-timeline-item">
                            @if (!string.IsNullOrWhiteSpace(item.Time))
                            {
                                <span class="event-preview-timeline-time">@item.Time</span>
                            }
                            @if (!string.IsNullOrWhiteSpace(item.Title))
                            {
                                <span class="event-preview-timeline-title">@item.Title</span>
                            }
                        </div>
                    }
                </div>
            }
        </div>
    </div>
    <div class="event-preview-audio" id="previewAudioWrapper" @(string.IsNullOrWhiteSpace(Model.MusicLink) ? "hidden" : "")>
        <span class="event-preview-label">Music</span>
        <div class="event-preview-audio-controls">
            <button class="btn btn-outline-primary btn-sm event-audio-toggle event-audio-float" type="button" data-audio-toggle data-audio-state="paused" aria-label="Play music">
                <span class="event-audio-icon" aria-hidden="true"></span>
            </button>
        </div>
        @if (Model.MusicEmbedType == "youtube")
        {
            <div class="event-preview-music-embed" data-audio-embed>
                <iframe id="previewAudio" src="@Model.MusicEmbedLinkMuted" data-audio-muted="@Model.MusicEmbedLinkMuted" data-audio-unmuted="@Model.MusicEmbedLink" title="Background music" allow="autoplay; encrypted-media" allowfullscreen></iframe>
            </div>
        }
        else
        {
            <audio id="previewAudio" src="@Model.MusicLink" loop autoplay data-audio-autoplay="true"></audio>
        }
    </div>
</div>
