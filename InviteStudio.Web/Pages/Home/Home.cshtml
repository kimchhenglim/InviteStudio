@page
@model InviteStudio.Web.Pages.Home.IndexModel
@{
    ViewData["Title"] = "Home";
}

<div class="home-hero">
    <div class="container">
        <div class="home-hero-content">
            <div>
                <h1>Your events</h1>
                <p class="home-subtitle">Pick an event to continue or start a new one.</p>
            </div>
            <div>
                <a class="btn btn-primary" asp-page="/Events/Create">Create event</a>
            </div>
        </div>
    </div>
</div>

<div class="container pb-5">
    <div class="row g-4">
        @if (Model.Events.Count == 0)
        {
            <div class="col-12">
                <div class="alert alert-light">No events yet. Create your first event to get started.</div>
            </div>
        }
        else
        {
            foreach (var eventItem in Model.Events)
            {
                <div class="col-12 col-md-6 col-xl-4">
                    <article class="event-card">
                        <div class="event-card-header">
                            <div>
                                <h2>@Model.GetEventTitle(eventItem)</h2>
                                <p class="event-date">@Model.FormatEventType(eventItem.EventType) &middot; @eventItem.EventDate.ToString("MMMM dd, yyyy")</p>
                            </div>
                            <span class="event-status">In progress</span>
                        </div>
                        <p class="event-description">@eventItem.Venue</p>
                        <div class="event-meta">
                            <div>
                                <span class="event-meta-label">Guests</span>
                                <span class="event-meta-value">--</span>
                            </div>
                            <div>
                                <span class="event-meta-label">Invites sent</span>
                                <span class="event-meta-value">--</span>
                            </div>
                        </div>
                        <a class="btn btn-outline-primary w-100" asp-page="/Events/Details" asp-route-id="@eventItem.Id">Open event</a>
                    </article>
                </div>
            }
        }
    </div>
</div>
